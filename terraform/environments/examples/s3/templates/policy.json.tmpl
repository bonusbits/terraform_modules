{
  "Version": "2012-10-17",
  "Id": "${policy_name}-bucket-policy",
  "Statement": [
    {
      "Sid": "Full Access for ${iam_user_name} User",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::${aws_account_id}:user/${iam_user_name}"
      },
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion",
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::${s3_bucket_id}",
        "arn:aws:s3:::${s3_bucket_id}/workspaces/*"
      ]
    }
  ]
}
